{
  "id": "docker",
  "name": "Docker",
  "env_vars": [
    {
      "name": "DOCKER_HOST",
      "type": "string",
      "required": false,
      "default": "unix:///var/run/docker.sock (macOS/Linux); npipe:////./pipe/docker_engine (Windows)",
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_CONTEXT",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_CONFIG",
      "type": "path",
      "required": false,
      "default": "~/.docker",
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_API_VERSION",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_CERT_PATH",
      "type": "path",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_TLS",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_TLS_VERIFY",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_DEFAULT_PLATFORM",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_HIDE_LEGACY_COMMANDS",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_CUSTOM_HEADERS",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "NO_COLOR",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "BUILDKIT_PROGRESS",
      "type": "enum",
      "required": false,
      "default": "auto",
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_BUILDKIT",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/build/buildkit/#getting-started"
    },
    {
      "name": "HTTP_PROXY",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "HTTPS_PROXY",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "NO_PROXY",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/docker/#environment-variables"
    },
    {
      "name": "DOCKER_DRIVER",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/dockerd/#environment-variables"
    },
    {
      "name": "DOCKER_TMPDIR",
      "type": "path",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/dockerd/#environment-variables"
    },
    {
      "name": "DOCKER_RAMDISK",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/dockerd/#environment-variables"
    },
    {
      "name": "MOBY_DISABLE_PIGZ",
      "type": "boolean",
      "required": false,
      "docs_url": "https://docs.docker.com/reference/cli/dockerd/#environment-variables"
    },
    {
      "name": "DOCKER_CONTENT_TRUST",
      "type": "boolean",
      "required": false,
      "default": false,
      "docs_url": "https://docs.docker.com/engine/security/trust/#client-enforcement-with-docker-content-trust"
    },
    {
      "name": "DOCKER_CONTENT_TRUST_SERVER",
      "type": "string",
      "required": false,
      "docs_url": "https://docs.docker.com/engine/security/trust/#client-enforcement-with-docker-content-trust"
    },
    {
      "name": "DOCKER_CONTENT_TRUST_ROOT_PASSPHRASE",
      "type": "secret",
      "required": false,
      "docs_url": "https://docs.docker.com/engine/security/trust/trust_automation/#add-a-delegation-private-key"
    },
    {
      "name": "DOCKER_CONTENT_TRUST_REPOSITORY_PASSPHRASE",
      "type": "secret",
      "required": false,
      "docs_url": "https://docs.docker.com/engine/security/trust/trust_automation/#add-a-delegation-private-key"
    }
  ]
}
